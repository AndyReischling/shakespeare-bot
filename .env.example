# ── The Rehearsal Room — environment ────────────────────────────────────────
# Copy to .env.local for local dev. All keys optional: the app degrades
# gracefully (an unattended demo must never dead-end on a missing key).

# Anthropic — the single dialogue engine (§1). If absent, the endpoint serves
# a deterministic "understudy" script so every screen still functions offline.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings for the file-based vector store (§1/§3). If absent, retrieval falls
# back to a deterministic local lexical scorer (no infra, still demoable).
# Supported providers: "openai" | "voyage" | "local"
EMBEDDING_PROVIDER=local
OPENAI_API_KEY=
VOYAGE_API_KEY=

# Voice (§7). Live TTS is OFF for the demo; audio is pre-rendered to /public/audio.
VOICE_LIVE=off
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Ops (§1): access gate + budgets. Enforced in middleware / route guards.
ACCESS_PASSWORD=
SESSION_TOKEN_BUDGET=60000
GLOBAL_DAILY_CALL_CAP=1500
IP_RATE_LIMIT_PER_MIN=20

# Session logging notice is always shown in-product; this toggles the sink.
LOG_SESSIONS=on
